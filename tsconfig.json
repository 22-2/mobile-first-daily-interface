{
  "compilerOptions": {
    "strict": true,
    "paths": {"*": ["./*"]},
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "esnext",
    "target": "esnext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strictPropertyInitialization": false,
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "types": ["obsidian-typings"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
