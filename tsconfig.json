{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "nodenext",
    "target": "esnext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "importHelpers": true,
    "isolatedModules": true,
    "strictPropertyInitialization": false,
    "lib": ["DOM", "ESNext"],
    "jsx": "react",
    "types": ["@types/bun", "obsidian-typings"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
