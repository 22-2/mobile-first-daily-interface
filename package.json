    "comlink": "^4.4.2",
    "monkey-around": "^3.0.0",
    "p-queue": "^9.1.1",
    "preact": "^10.29.1",
    "react": "~19.2.4",
    "react-dom": "~19.2.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "virtua": "^0.49.0",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "electron": "41.0.3"
    },
    "onlyBuiltDependencies": [
      "electron",
      "obsidian-e2e-toolkit"
    ]
  }
}
