{
  "name": "mobile-first-daily-interface",
  "version": "2.0.3",
  "type": "module",
  "description": "TODO",
  "main": "main.js",
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:analyze": "vite build -- --analyze",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "pnpm tsc --noEmit -skipLibCheck",
    "format": "pnpx organize-imports-cli tsconfig.json && pnpx prettier --editorconfig --write ./src && pnpm exec eslint --fix",
    "pre:push": "pnpm typecheck && pnpm run test",
    "ci": "pnpm install && pnpm run build && pnpm run test",
    "release": "pnpm ci && pnpm version-bump.mts ${VERSION} && git add package.json manifest.json versions.json pnpm.lockb && git commit -m ${VERSION} && git tag ${VERSION} && git push --tags && git push"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@22-2/esbuild-plugin-obsidian-copy": "0.1.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@vitejs/devtools": "^0.1.13",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "41.1.1",
    "es-toolkit": "^1.45.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "moment": "^2.30.1",
    "obsidian-e2e-toolkit": "github:22-2/obsidian-e2e-toolkit#1.0.0",
    "obsidian-typings": "^5.18.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-inspect": "12.0.0-beta.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@22-2/obsidian-magical-editor": "1.0.3",
