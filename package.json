  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "fastbuild": "node esbuild.config.mjs fast-production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "type": "pnpm tsc --noEmit -skipLibCheck",
    "pre:push": "tsc -noEmit -skipLibCheck && pnpm run test",
    "ci": "pnpm install && pnpm run build && pnpm run test",
    "release": "pnpm ci && pnpm version-bump.mts ${VERSION} && git add package.json manifest.json versions.json pnpm.lockb && git commit -m ${VERSION} && git tag ${VERSION} && git push --tags && git push"
  },
