    "es-toolkit": "^1.49.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
